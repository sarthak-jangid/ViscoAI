{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution" : "nodenext",
    "target": "ES2022",

    "lib": ["ES2022"],
    "types": ["node"],
    
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
  }
}
